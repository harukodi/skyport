{
	acme_dns cloudflare {env.CLOUDFLARE_AUTH_TOKEN}
	default_bind 0.0.0.0
	https_port 443
}

(security_headers) {
	header {
		-Server
		-X-Powered-By
        -X-Xss-Protection
        -X-Content-Type-Options
		-Alt-Svc
	}
}

import {{ s3_facade_config }}
{{ domain_name }} {
	import security_headers
	import s3_facade
	tls {
		protocols tls1.3 tls1.3
		ciphers TLS_AES_256_GCM_SHA384 TLS_CHACHA20_POLY1305_SHA256
		curves x25519
	}

	@xray_probe {
		path /{{ xray_path }}/check
	}

	handle @xray_probe {
		respond 204
	}

	@xray_xhttp {
		path /{{ xray_path }}/*
	}
	handle @xray_xhttp {
		reverse_proxy @xray_xhttp 0.0.0.0:8443 {
			header_up X-Real-IP {http.request.header.CF-Connecting-IP}
			header_up X-Forwarded-For {http.request.header.CF-Connecting-IP}
			flush_interval -1
			transport http {
				versions h2c
			}
		}
	}
	
{% if enable_skyport_ui %}
	@frontend {
	    path /{{ frontend_path }}/*
	}
	handle @frontend {
	    uri strip_prefix /{{ frontend_path }}
	    reverse_proxy 0.0.0.0:8080 {
			header_up X-Forwarded-Prefix /{{ frontend_path }}
		}
	}
{% endif %}
}