{
    "log": {
        "loglevel": "warning"
    },
    "observatory": {
        "subjectSelector": [
            "WARP_PROXY_OUTBOUND"
        ],
        "probeUrl": "https://${domain_name}:${port}/${xray_path}/check",
        "probeInterval": "2s",
        "enableConcurrency": false
    },
    "inbounds": [
        {
            "tag": "VLESS_INBOUND_XHTTP",
            "listen": "0.0.0.0",
            "port": 8443,
            "protocol": "vless",
            "settings": {
                "clients": [
                    {
                        "id": "${xray_uuid}",
                        "flow": "xtls-rprx-vision"
                    }
                ],
                "decryption": "${xray_decryption_key}"
            },
            "streamSettings": {
                "network": "xhttp",
                "xhttpSettings": {
                    "mode": "auto",
                    "path": "${xray_path}"
                }
            }
        }
    ],
    "outbounds": [
        {
            "protocol": "freedom",
            "settings": {},
            "tag": "DIRECT"
        },
        {
            "protocol": "socks",
            "settings": {
                "servers": [
                    {
                        "address": "127.0.0.1",
                        "port": 40000
                    }
                ]
            },
            "tag": "WARP_PROXY_OUTBOUND"
        },
        {
            "protocol": "blackhole",
            "settings": {},
            "tag": "BLOCK"
        }
    ],
    "routing": {
        "balancers": [
            {
                "tag": "EGRESS_BALANCER",
                "selector": [
                    "WARP_PROXY_OUTBOUND"
                ],
                "fallbackTag": "DIRECT",
                "strategy": {
                    "type": "random"
                }
            }
        ],
        "rules": [
            {
                "ip": [
                    "geoip:private"
                ],
                "outboundTag": "BLOCK",
                "type": "field"
            },
            {
                "domain": [
                    "localhost"
                ],
                "outboundTag": "BLOCK",
                "type": "field"
            },
            {
                "type": "field",
                "network": "tcp,udp",
                "balancerTag": "EGRESS_BALANCER"
            }
        ]
    }
}